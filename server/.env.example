# Server
PORT=4000

# Database: leave both blank for local dev (uses a local SQLite file via libsql).
# In production (Netlify), set these to a Turso database — see README for setup —
# since serverless functions have no persistent local filesystem.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Time zone used for all conference dates and timestamps
TIME_ZONE=America/New_York

# Organizer passcode required to access organizer-only screens/endpoints
ORGANIZER_PASSCODE=changeme123

# CORS origin for the web app during local dev
WEB_ORIGIN=http://localhost:5173
