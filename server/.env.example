# Server
PORT=4000

# No database account needed. Data is stored in Netlify Blobs when deployed
# (zero-config — Netlify injects the credentials automatically) or in a local
# JSON file under server/data/ during local dev.

# Time zone used for all conference dates and timestamps
TIME_ZONE=America/New_York

# Organizer passcode required to access organizer-only screens/endpoints
ORGANIZER_PASSCODE=changeme123

# CORS origin for the web app during local dev
WEB_ORIGIN=http://localhost:5173
